無法用 synthetic process 重現。"}],"contract":{"artifact_policy":{"allow_provider_payloads":false,"default_retention":"session"},"conclusion_author":"host","confirmation":{"card_sha256":"70f3fdb2d315e9a1d4e4552e012628045d72d931aa2396393f66c3ded817a193","confirmed_at":"2026-07-13T10:30:00Z","confirmed_by":"user","referenced_records_sha256":"1f5985cd571957059d593090a78c580e8a513117480bcafdbec9578a65f48ec5","registry_sha256":"1713cf62606c88462fcd385c155beaac59e8a8ebf4eab32435b9f944bb377589"},"durability":"canonical_package","evidence_floor":{"minimum_load_bearing_claims":1,"require_raw_artifacts":true},"execution":"external_managed","posture":"decision","provider_reports_role":"discovery_only","question":"What is the smallest reliable acceptance test for Parallax's next long-running pipeline change?","research_workflow":"host_led_v1","resource_envelope":{"cost_budget":{"deep":0,"free":"unlimited","profile":"light","search":5},"external":{"allowed_endpoint_classes":[],"estimated_spend_usd":{"hard_cap":false,"maximum":0.0,"minimum":0.0},"local_file_egress":false,"max_wall_time_seconds":7200,"metered_ceiling":{"deep":0,"network_experiment":0,"probe":15,"processor":0,"transport":0},"network_experiment_endpoints":[],"raw_storage_bytes":20971520},"host":{"admitted_characters":32000,"context_class":"standard","estimated_tokens":8000},"local":{"admitted_output_characters":16000,"max_wall_time_seconds":1200,"network_egress":false},"physical_ceiling":{"deep":0,"host_retrieval":3,"local":1,"network_experiment":0,"organizer_pass":1,"probe":15,"processor":0,"transport":0}},"scout_route":"host-web","stage_permit_map":[{"category":"host_retrieval","count":1,"invocations":1,"reserved":false,"route":"host-web","stage":"primary_scout"},{"category":"local","count":1,"invocations":1,"reserved":false,"route":"local","stage":"local_applicability"},{"category":"host_retrieval","count":1,"invocations":1,"reserved":true,"route":"host-web","stage":"anti_lock_in"},{"category":"host_retrieval","count":1,"invocations":1,"reserved":true,"route":"host-web","stage":"verification"},{"category":"organizer_pass","count":1,"invocations":1,"reserved":true,"route":"host","stage":"final_inference_review"},{"category":"probe","count":5,"invocations":5,"reserved":true,"route":"exa","stage":"verification"},{"category":"probe","count":5,"invocations":5,"reserved":true,"route":"openalex","stage":"verification"},{"category":"probe","count":5,"invocations":5,"reserved":true,"route":"sonar","stage":"verification"}],"tier":"custom"},"engineering_handoff":{"acceptance_tests":["執行新的 temp-root carrier test => failure 被誠實記錄、sentinel 行為符合 gating contract、final status 已落盤且 lock 已釋放"],"constraints":["若風險依賴真實 upstream rate limit、資料量或 OS-specific process tree，需額外加有界 integration probe。"],"safe_actions":[{"depends_on_claim_ids":["C1","C2"],"description":"先複製現有 timeout falsifier，只替換第一個 synthetic step 與 assertions；保持 temp root、無外部網路。","id":"SA1","reversible":true}]},"evidence":[{"applicability":"checked","artifact_id":"A1","entailment":"entailed","excerpt":"Hard guarantees the legacy shell wrappers could not make:\n\n- every step runs in its own process group with a hard timeout; a hung\n  fetch is killed, recorded, and the job continues honestly\n- a crashed run still writes its final status (try/finally) — no more\n  ops_status stuck at \"running\" after a mid-run death\n- a lock left behind by a dead process is detected (pid liveness) and\n  taken over with a notification, instead of blocking every subsequent\n  night until a human notices\n- the run ledger is appended before the process exits, success or not\n","excerpt_end":557,"excerpt_start":0,"id":"E1","origin_id":"OR1","retrieved_at":"2026-07-13T10:30:04Z","source_id":"S1","source_tier":"T1"},{"applicability":"checked","artifact_id":"A2","entailment":"entailed","excerpt":"    def test_falsifier_timeout_kills_hung_step(self) -> None:\n        \"\"\"Plan success criterion 4: a hung step is killed at its deadline\n        and the job continues with an honest verdict.\"\"\"\n        steps = [\n            _step(\"hang\", \"import time; time.sleep(60)\", timeout_s=2),\n            _step(\"after\", \"print('still ran')\"),\n        ]\n        started = time.monotonic()\n        rc = self._run(steps)\n        elapsed = time.monotonic() - started\n        self.assertLess(elapsed, 40)  # not 60s — the hang was killed\n        self.assertEqual(rc, Verdict.FAIL.process_exit_code)\n        record = self._ledger_runs()[0]\n        hang = record[\"steps\"][0]\n        self.assertTrue(hang[\"timed_out\"])\n        self.assertEqual(hang[\"verdict\"], \"fail\")\n        self.assertEqual(record[\"steps\"][1][\"verdict\"], \"pass\")  # pipeline continued\n","excerpt_end":839,"excerpt_start":0,"id":"E2","origin_id":"OR2","retrieved_at":"2026-07-13T10:30:05Z","source_id":"S2","source_tier":"T1"}],"evidence_deltas":[],"framing":{"assumptions":["下一個 long-running change 仍由 ops carrier 的 JobSpec/StepSpec 執行。"],"exclusions":["不以整條 weekly pipeline 或真實外部 API 作為第一個 acceptance test。"],"question":"What is the smallest reliable acceptance test for Parallax's next long-running pipeline change?"},"hypotheses":[],"inference_joints":[{"adversarially_reviewed":true,"claim_ids":["C1","C2"],"id":"J1","weakest_joint":true}],"observations":[],"open_questions":[],"planned_checks":[],"retrieval_occurrences":[],"schema_version":"2.0","session":{"contract_semantics":"pure_trigger_v3","created_at":"2026-07-13T12:30:01Z","id":"deep-bdd8585a38ec4856af2611da4ea9c54f","revision":3,"updated_at":"2026-07-13T12:30:12Z"},"source_origins":[{"id":"OR1","independent":true,"kind":"repository-source-of-record"},{"id":"OR2","independent":true,"kind":"repository-source-of-record"}],"sources":[{"canonical_source_key":"https://github.com/jechiu16/parallax/blob/a8c4284e73156ac62e61d5e70a273781342c55fb/src/parallax/ops/engine.py","direct_fetch":true,"id":"S1","origin_id":"OR1","tier":"T1","title":"Parallax ops carrier engine","upstream_key":"github.com/jechiu16/parallax","url":"https://github.com/jechiu16/parallax/blob/a8c4284e73156ac62e61d5e70a273781342c55fb/src/parallax/ops/engine.py"},{"canonical_source_key":"https://github.com/jechiu16/parallax/blob/a8c4284e73156ac62e61d5e70a273781342c55fb/tests/test_ops_carrier.py","direct_fetch":true,"id":"S2","origin_id":"OR2","tier":"T1","title":"Ops carrier timeout falsifier test","upstream_key":"github.com/jechiu16/parallax","url":"https://github.com/jechiu16/parallax/blob/a8c4284e73156ac62e61d5e70a273781342c55fb/tests/test_ops_carrier.py"}],"summary":{"decision":"新增一個 carrier-level temp-root test：第一個 synthetic step 精準重現本次 failure mode，第二個 sentinel；assert timeout/exit verdict、ledger record、後續 step、final status 與 lock release。另用 dry-run 只鎖 argv/timeout/gating。","human_recommendation":"不要跑完整 production pipeline 才驗收；先以單一 failure-path integration test 取得最強訊號，再視外部語意補窄的 live probe。","human_status":"已把建議對齊現有 ops carrier 的實際 failure contract 與既有 falsifier。","load_bearing_claim_ids":["C1","C2"],"status":"PASS"},"verification":[{"checked_claim_ids":["C1","C2"],"completed":true,"corrected_claim_ids":[],"disposition":"交叉檢查 engine guarantees 與既有 timeout falsifier；兩者一致，未發現需要修正或無法驗證的 claim。","id":"VR1","kind":"targeted_reverification","unverifiable_claim_ids":[]}]}
